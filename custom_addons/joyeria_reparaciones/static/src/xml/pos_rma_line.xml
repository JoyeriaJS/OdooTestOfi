<odoo>
    <templates xml:space="preserve">

        <t t-inherit="point_of_sale.Orderline"
           t-inherit-mode="extension">

            <xpath expr="//div[contains(@class, 'product-name')]" position="after">

                <t t-if="props.line && props.line.numero_rma">

                    <div style="font-size:12px; opacity:0.7; margin-left:10px;">

                        <div>
                            Subtotal:
                            <t t-esc="props.line.subtotal_rma || 0"/>
                        </div>

                        <div>
                            Abono:
                            <t t-esc="props.line.abono_rma || 0"/>
                        </div>

                        <div>
                            <b>
                                Saldo:
                                <t t-esc="props.line.saldo_rma || 0"/>
                            </b>
                        </div>

                    </div>

                </t>

            </xpath>

        </t>

    </templates>
</odoo>