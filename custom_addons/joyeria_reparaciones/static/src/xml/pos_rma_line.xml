<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="joyeria_reparaciones.PosRMALine"
       t-inherit="point_of_sale.Orderline"
       t-inherit-mode="extension">

        <!-- 👇 ESTE ES EL BUENO -->
        <xpath expr="//div[contains(@class, 'product-name')]" position="after">

            <t t-if="props.line.numero_rma">

                <div style="font-size:12px; color:#666; margin-left:10px;">

                    <div>
                        Subtotal: 
                        <t t-out="props.line.subtotal_rma or 0"/>
                    </div>

                    <div>
                        Abono: 
                        <t t-out="props.line.abono_rma or 0"/>
                    </div>

                </div>

            </t>

        </xpath>

    </t>

</templates>