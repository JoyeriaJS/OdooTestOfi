<odoo>
    <templates id="template" xml:space="preserve">

        <t t-name="joyeria_reparaciones.PosRMALine"
           t-inherit="point_of_sale.Orderline"
           t-inherit-mode="extension">

            <!-- Insertar dentro del bloque principal del line -->
            <xpath expr="//div[hasclass('info-list')]" position="inside">

                <t t-if="props.line.numero_rma">

                    <div style="font-size:12px; opacity:0.7; margin-top:4px;">

                        <div>
                            Subtotal:
                            <t t-out="props.line.subtotal_rma"/>
                        </div>

                        <div>
                            Abono:
                            <t t-out="props.line.abono_rma"/>
                        </div>

                        <div>
                            <b>
                                Saldo:
                                <t t-out="props.line.saldo_rma"/>
                            </b>
                        </div>

                    </div>

                </t>

            </xpath>

        </t>

    </templates>
</odoo>