<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="joyeria_reparaciones.PosRMALine"
       t-inherit="point_of_sale.OrderlineItem"
       t-inherit-mode="extension">

        <!-- 👇 usamos el contenedor principal real -->
        <xpath expr="//div[contains(@class, 'orderline')]" position="inside">

            <t t-if="props.line.numero_rma">

                <div style="font-size:12px; color:#666; margin-left:15px; margin-top:4px;">

                    <div>
                        Subtotal: 
                        <t t-out="props.line.subtotal_rma || 0"/>
                    </div>

                    <div>
                        Abono: 
                        <t t-out="props.line.abono_rma || 0"/>
                    </div>

                </div>

            </t>

        </xpath>

    </t>

</templates>