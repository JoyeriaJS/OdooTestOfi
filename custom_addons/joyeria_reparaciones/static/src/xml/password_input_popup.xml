<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="joyeria_reparaciones.PasswordInputPopup">
        <Dialog title="props.title || 'Ingrese clave'">
            <div class="p-3">
                <t t-if="props.body">
                    <div class="mb-2">
                        <t t-esc="props.body"/>
                    </div>
                </t>

                <input
                    type="password"
                    class="form-control"
                    t-model="state.value"
                    t-att-placeholder="props.placeholder || 'Clave'"
                    t-on-keydown="(ev) => { if (ev.key === 'Enter') this.confirm(); }"
                />
            </div>

            <t t-set-slot="footer">
                <button class="btn btn-secondary" t-on-click="cancel">
                    Cancelar
                </button>
                <button class="btn btn-primary" t-on-click="confirm">
                    Confirmar
                </button>
            </t>
        </Dialog>
    </t>

</templates>